.installed.cfg
*.egg
MANIFEST
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
*.mo
*.pot
*.log
.venv/
venv/
env/
ENV/
.venv*/

# --------------------------
# Node.js / JavaScript
# --------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Package manager lock files (optionally committed)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
# bun.lockb

# --------------------------
# Next.js
# --------------------------
.next/
out/

