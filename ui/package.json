{
  "name": "mozilla-data-docs-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:ui\" \"npm run dev:proxy\" --names ui,proxy --prefix-colors blue,green --kill-others",
    "dev:debug": "LOG_LEVEL=debug npm run dev",
    "dev:proxy": "./scripts/run-proxy.sh || scripts/run-proxy.bat",
    "dev:ui": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "install:proxy": "./scripts/setup-proxy.sh || scripts\\setup-proxy.bat",
    "postinstall": "npm run install:proxy"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.42",
    "@copilotkit/react-core": "1.50.0",
    "@copilotkit/react-ui": "1.50.0",
    "@copilotkit/runtime": "1.50.0",
    "firebase": "^11.1.0",
    "next": "16.0.8",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "shiki": "^3.19.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.0.8",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
